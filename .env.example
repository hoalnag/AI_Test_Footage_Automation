VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
VIMEO_ACCESS_TOKEN=

# Folder in the Vimeo account to upload into (optional, leave blank for none)
VIMEO_FOLDER_URI=

# Base URL where docs/ is published (your GitHub Pages URL), e.g.
# https://yourname.github.io/AI_Test_Footage_Automation
SITE_BASE_URL=

# Public URL of your Cargo gallery page — used for the "Back to gallery" link
# on each prompt detail page.
GALLERY_URL=
